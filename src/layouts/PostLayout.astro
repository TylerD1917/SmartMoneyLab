---
import BaseLayout from "./BaseLayout.astro";
import Disclaimer from "../components/Disclaimer.astro";

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  author?: string;
  ogImage?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  author = "SmartMoneyLab",
  ogImage,
} = Astro.props;

const fmt = new Intl.DateTimeFormat("it-IT", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---
<BaseLayout title={title} description={description} ogImage={ogImage}>
  <article class="mx-auto max-w-3xl">
    <header class="mb-8 border-b border-slate-200 pb-6 dark:border-slate-800">
      <div class="mb-3 flex flex-wrap items-center gap-2 text-xs uppercase tracking-wider text-slate-500 dark:text-slate-400">
        <time datetime={pubDate.toISOString()}>{fmt.format(pubDate)}</time>
        {updatedDate && (
          <>
            <span aria-hidden="true">·</span>
            <span>Agg. {fmt.format(updatedDate)}</span>
          </>
        )}
        <span aria-hidden="true">·</span>
        <span>{author}</span>
      </div>
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900 dark:text-slate-50 sm:text-4xl">
        {title}
      </h1>
      <p class="mt-3 text-lg text-slate-600 dark:text-slate-300">{description}</p>
      {tags.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <li class="rounded-full border border-slate-200 px-2.5 py-0.5 text-xs text-slate-600 dark:border-slate-700 dark:text-slate-300">
              #{tag}
            </li>
          ))}
        </ul>
      )}
    </header>

    <div class="prose prose-slate max-w-none dark:prose-invert">
      <slot />
    </div>

    <Disclaimer />
  </article>
</BaseLayout>
