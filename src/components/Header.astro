---
import ThemeToggle from "./ThemeToggle.astro";
const navItems = [
  { label: "Articoli", href: "/" },
  { label: "Chi siamo", href: "/chi-siamo" },
];
const path = Astro.url.pathname;
---
<header class="border-b border-slate-200 dark:border-slate-800">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-5">
    <a href="/" class="group flex items-center gap-2">
      <span class="inline-flex h-7 w-7 items-center justify-center rounded-md bg-blue-900 text-white text-xs font-semibold tracking-tight dark:bg-blue-400 dark:text-slate-950">
        SML
      </span>
      <span class="font-semibold tracking-tight text-slate-900 dark:text-slate-50">
        SmartMoneyLab
      </span>
    </a>
    <nav class="flex items-center gap-1 sm:gap-3">
      {
        navItems.map((item) => {
          const active = item.href === "/" ? path === "/" : path.startsWith(item.href);
          return (
            <a
              href={item.href}
              class:list={[
                "rounded-md px-3 py-1.5 text-sm transition",
                active
                  ? "text-blue-900 dark:text-blue-400 font-medium"
                  : "text-slate-600 hover:text-slate-900 dark:text-slate-300 dark:hover:text-slate-50",
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
      <ThemeToggle />
    </nav>
  </div>
</header>
