      &copy; {year} SmartMoneyLab — Finanza personale e analisi quantitativa.
    </div>
    <div class="flex flex-wrap gap-x-4 gap-y-2">
      <a
        href="https://x.com/smartmoneylabIT"
        target="_blank"
        rel="me noopener"
        class="hover:text-slate-900 dark:hover:text-slate-100"
      >X</a>
      <a
        href="https://instagram.com/smartmoneylab_it"
        target="_blank"
        rel="me noopener"
        class="hover:text-slate-900 dark:hover:text-slate-100"
